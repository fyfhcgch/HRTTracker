<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 通知权限（Android 13+） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 网络访问权限（用于检查更新） -->
    <uses-permission android:name="android.permission.INTERNET" />
    
    <!-- 精确闹钟权限（Android 12+） -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.HRTTracker"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="36">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.HRTTracker"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 用药提醒广播接收器 -->
        <receiver
            android:name=".reminder.MedicationReminderReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- HRT Tracker 组合微件（用药提醒 + 快速添加） -->
        <receiver
            android:name=".widget.HRTTrackerWidgetReceiver"
            android:label="@string/widget_combined_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/hrt_tracker_widget_info" />
        </receiver>

        <!-- 微件配置 Activity -->
        <activity
            android:name=".widget.HRTTrackerWidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.HRTTracker">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>
    </application>

</manifest>