<?xml version="1.0" encoding="utf-8"?>
<!-- Clock-ring icon for previewLayout (shape drawables only — VectorDrawables are unreliable in RemoteViews context) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer ring -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#304962" />
        </shape>
    </item>
    <!-- Hour hand (top-centre) -->
    <item
        android:top="2dp"
        android:left="7dp"
        android:right="7dp"
        android:bottom="10dp">
        <shape android:shape="rectangle">
            <solid android:color="#304962" />
            <corners android:radius="1dp" />
        </shape>
    </item>
    <!-- Minute hand (centre-right) -->
    <item
        android:top="7dp"
        android:left="9dp"
        android:right="2dp"
        android:bottom="7dp">
        <shape android:shape="rectangle">
            <solid android:color="#304962" />
            <corners android:radius="1dp" />
        </shape>
    </item>
</layer-list>
